# Copy this to .env and fill in your values

# agent.py: URL of the Railway WebSocket relay
RELAY_URL=wss://your-app.railway.app/ws/agent

# Puerto serial del robot (opcional — si no se setea, se auto-detecta)
# USB cable (WSL2): dejar vacío, la auto-detección encuentra CH340/CP210x
# Bluetooth (WSL2): setear al ttyS correspondiente al COM de Windows
#   Ejemplo: si Windows asignó COM7 al HC-05 → ROBOT_PORT=/dev/ttyS7
# Windows nativo: ROBOT_PORT=COM5
# macOS (Bluetooth): ROBOT_PORT=/dev/tty.HC-05-DevB
# ROBOT_PORT=
