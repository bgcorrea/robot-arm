# Copiá este archivo a .env y completá los valores

# URL del relay (Railway en producción, localhost en desarrollo)
RELAY_URL=ws://localhost:8000/ws/agent
# RELAY_URL=wss://tu-app.railway.app/ws/agent

# Dirección MAC del módulo BLE (evita el scan de 6s en cada arranque)
BLE_ADDRESS=70:3E:97:93:29:A5

# Puerto serial (solo si usás USB en lugar de BLE)
# ROBOT_PORT=COM5
